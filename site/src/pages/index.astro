      .band__bg { position: absolute; inset: 0; z-index: 0; overflow: hidden;
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 34%, #000 66%, transparent 100%);
        mask-image: linear-gradient(to bottom, transparent 0%, #000 34%, #000 66%, transparent 100%); }
      .band__slide { position: absolute; inset: 0; background: center/cover no-repeat;
        opacity: 0; will-change: transform, opacity;
        animation: bandSlide 36s ease-in-out infinite; }
      .band__slide:nth-child(1) { animation-delay: 0s; }
      .band__slide:nth-child(2) { animation-delay: -7.2s; }
      .band__slide:nth-child(3) { animation-delay: -14.4s; }
