      .band { position: relative; overflow: hidden; padding: clamp(80px, 14vh, 180px) 20px; display: grid; place-items: center; }
      /* Crossfading slideshow of processed pages, faded behind the copy.
         The container is taller than the band and masked top+bottom so it
