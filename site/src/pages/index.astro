---
const GITHUB = 'https://github.com/yb85/aglaia';
// Fixed-name "latest" artifacts published by the release CI — these URLs never
// need a version, so they always point at the newest build. The page renders
// macOS (the most mature build) first; client JS swaps in the visitor's OS.
const REL = `${GITHUB}/releases/latest/download`;
const DOWNLOADS = {
  mac:     { url: `${REL}/Aglaia-macos-arm64.dmg`,       name: 'macOS',   sub: 'Apple Silicon · .dmg · Metal GPU' },
  windows: { url: `${REL}/Aglaia-windows-x64-setup.exe`, name: 'Windows', sub: 'x64 · installer · CPU' },
  linux:   { url: `${REL}/Aglaia-x86_64.AppImage`,       name: 'Linux',   sub: 'x86_64 · AppImage · CPU' },
};
const DOWNLOAD = DOWNLOADS.mac.url;   // default / fallback (nav button, no-JS)
const KOFI = 'https://ko-fi.com/yb_85';

// Icons match the app sidebar tabs (lucide): camera, sliders-horizontal,
// scan-text (all stroke) and export (fill).
const steps = [
  { n: '01', t: 'Capture / Import', d: 'Point your phone or webcam at the page and shoot — hands-free with voice control, no flatbed, no app-switching. Already have files? Import your PDFs and images straight in.',
    svg: '<path d="M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z"/><circle cx="12" cy="13" r="3"/>' },
  { n: '02', t: 'Process', d: 'Isolate the text content, straighten it, and remove perspective and page-curvature distortion. Make your text pop with advanced binarization techniques.',
    svg: '<line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/>' },
  { n: '03', t: 'Read', d: 'Fast and coarse or slow and precise; local (Apple Vision, Surya, PaddleOCR-VL) or cloud-based (Mistral OCR) — use the OCR that suits your project.',
    svg: '<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/>' },
  { n: '04', t: 'Export', d: 'A clean, searchable PDF for your digital archives or printouts? A well-structured Markdown file to feed your favorite LLM workflows? Aglaïa gives you what you need.',
    fill: true, svg: '<path d="m16.95 5.968l-1.414 1.414L13 4.846v12.196h-2V4.847L8.465 7.382L7.05 5.968L12 1.018z"/><path d="M5 20.982v-10h4v-2H3v14h18v-14h-6v2h4v10z"/>' },
];

// lucide icons (inner SVG): square-terminal, blocks, plug
const powers = [
  { t: 'Full CLI automation', d: 'Run the end-to-end pipeline from the command line.',
    svg: '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="m7 11 2-2-2-2"/><path d="M11 13h4"/>' },
  { t: 'Versatile plugin system', d: 'The task at hand gets specific? Build your own processing elements in Python.',
    svg: '<path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/>' },
  { t: 'Freedom to choose', d: 'Have a favorite OCR provider? Need to export to cloud storage? Write your own adapters.',
    svg: '<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H7"/>' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Aglaïa — powerful, fast & free book scanner</title>
    <meta name="description" content="From your phone camera to a curated, searchable PDF — at your desk, in the library, or wherever you are. No flatbed, no scanning rig. Just you, your laptop and your phone." />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <noscript><style>.reveal{opacity:1;transform:none}</style></noscript>
  </head>
  <body>
    <header class="nav" id="nav">
      <a class="brand" href="/">
        <img class="brand__logo" src="/aglaia-dark.png" width="84" height="34" alt="Aglaïa" />
        <span class="brand__tag">BOOKSCANNER</span>
      </a>
      <nav>
        <a href="/docs">Docs</a>
        <a href={GITHUB}>GitHub</a>
        <a class="nav-tip" href={KOFI} target="_blank" rel="noopener" aria-label="Tip the developer">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
          Tip
        </a>
        <a class="btn btn--sm" href={DOWNLOAD} data-download>Download</a>
      </nav>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero__glow" data-parallax="0.18"></div>
        <div class="hero__inner">
          <img class="hero__logo" src="/aglaia-dark.png" width="420" height="172" fetchpriority="high" decoding="async" alt="Aglaïa" />
          <p class="eyebrow reveal">The powerful, fast &amp; free book scanner</p>
          <h1 class="reveal">Give your books<br /><span>the digital life<br />they deserve.</span></h1>
          <p class="lede reveal">
            <span class="lede__l1">From your phone camera to a curated, searchable PDF</span>
            <span class="lede__l2">At your desk, in the library, or wherever you are.</span>
            <span class="lede__l3">No flatbed, no bulky rig: just you, your laptop and your phone.</span>
          </p>
          <div class="cta reveal">
            <div class="dl">
              <a class="btn btn--lg dl__main" href={DOWNLOADS.mac.url} data-download data-download-os>
                <span class="dl__label">Download for {DOWNLOADS.mac.name}</span>
                <span class="dl__sub">{DOWNLOADS.mac.sub}</span>
              </a>
              <button class="btn btn--lg dl__toggle" type="button"
                      aria-haspopup="true" aria-expanded="false" aria-label="Choose another platform">▾</button>
              <div class="dl__menu" role="menu" hidden>
                <a role="menuitem" data-os="mac"     href={DOWNLOADS.mac.url}><b>macOS</b><span>{DOWNLOADS.mac.sub}</span></a>
                <a role="menuitem" data-os="windows" href={DOWNLOADS.windows.url}><b>Windows</b><span>{DOWNLOADS.windows.sub}</span></a>
                <a role="menuitem" data-os="linux"   href={DOWNLOADS.linux.url}><b>Linux</b><span>{DOWNLOADS.linux.sub}</span></a>
              </div>
            </div>
            <a class="btn btn--ghost btn--lg btn--stack" href="#install" data-cli>
              <span class="dl__label">CLI installation</span>
              <span class="dl__sub">uv · pip · brew</span>
            </a>
          </div>
          <p class="cta__note reveal">CUDA GPU acceleration available via <a href="#install">CLI install</a> on Linux / WSL2.</p>
          <p class="fineprint reveal">macOS · Windows · Linux — free &amp; source-available.</p>
          <a class="tip reveal" href={KOFI} target="_blank" rel="noopener">
            <span class="tip__heart" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
            </span>
            <span class="tip__label">Tip the developer</span>
          </a>
        </div>
      </section>

      <!-- PROBLEM -->
      <section class="band">
        <div class="band__bg" aria-hidden="true">
          <div class="band__slide" style="background-image:url(/landing/band-slide-1.webp)"></div>
          <div class="band__slide" style="background-image:url(/landing/band-slide-2.webp)"></div>
          <div class="band__slide" style="background-image:url(/landing/band-slide-3.webp)"></div>
          <div class="band__slide" style="background-image:url(/landing/band-slide-4.webp)"></div>
          <div class="band__slide" style="background-image:url(/landing/band-slide-5.webp)"></div>
        </div>
        <div class="band__inner reveal">
          <h2>You don't have to settle<br />for <span>crufty book photos.</span></h2>
          <p class="band__lead">You don't have to endure <span class="hl">endless flatbed scanning</span> sessions either.</p>
          <p>Curved pages, skew, perspective, uneven illumination, <br class="brk" />and dozens of issues that make you go « eewww… » when you look at your documents. <br class="brk" />Aglaïa turns the camera and the laptop you already have into a proper scanner. <br class="brk" /><span class="hl hl--glow">All automatic. Fully customizable.</span></p>
        </div>
      </section>

      <!-- BEFORE / AFTER SWIPES -->
      <section class="compare">
        <div class="compare__head reveal">
          <h2><span>3</span> scanning challenges,<br /><span>1</span> standard pipeline to rule them all…</h2>
          <p class="compare__note">The following examples were all run with default settings. No fiddling needed.</p>
        </div>
        <div class="compare__grid compare__grid--3">
          <figure class="ba-item reveal">
            <div class="ba" style="--pos:52%">
              <img class="ba__img" src="/landing/before.webp" width="760" height="601"
                   alt="A book spread photographed at a desk under overhead light." />
              <div class="ba__after">
                <img class="ba__img" src="/landing/after.webp" width="760" height="601"
                     alt="The same spread after Aglaïa: two flat, deskewed, dewarped pages." />
              </div>
              <span class="ba__divider" aria-hidden="true"></span>
              <span class="ba__tag ba__tag--l">before</span>
              <span class="ba__tag ba__tag--r">after</span>
              <input class="ba__range" type="range" min="0" max="100" value="52" aria-label="Reveal the processed page" />
            </div>
            <figcaption><b>Easy mode</b> 😁 at a desk with overhead lights</figcaption>
          </figure>
          <figure class="ba-item reveal">
            <div class="ba" style="--pos:52%">
              <img class="ba__img" src="/landing/lit-before.webp" width="760" height="590"
                   alt="A book spread under uneven light — one page in shadow, the other bright." />
              <div class="ba__after">
                <img class="ba__img" src="/landing/lit-after.webp" width="760" height="590"
                     alt="The same spread after Aglaïa: even, clean, binarized text edge to edge." />
              </div>
              <span class="ba__divider" aria-hidden="true"></span>
              <span class="ba__tag ba__tag--l">before</span>
              <span class="ba__tag ba__tag--r">after</span>
              <input class="ba__range" type="range" min="0" max="100" value="52" aria-label="Reveal the processed page" />
            </div>
            <figcaption><b>Medium mode</b> 🤨 on a library chair, uneven illumination</figcaption>
          </figure>
          <figure class="ba-item reveal">
            <div class="ba" style="--pos:52%">
              <img class="ba__img" src="/landing/curl-before.webp" width="760" height="574"
                   alt="A thick book whose pages curl steeply into the spine." />
              <div class="ba__after">
                <img class="ba__img" src="/landing/curl-after.webp" width="760" height="574"
                     alt="The same spread after Aglaïa: the curl flattened, baselines straight." />
              </div>
              <span class="ba__divider" aria-hidden="true"></span>
              <span class="ba__tag ba__tag--l">before</span>
              <span class="ba__tag ba__tag--r">after</span>
              <input class="ba__range" type="range" min="0" max="100" value="52" aria-label="Reveal the processed page" />
            </div>
            <figcaption><b>Hard mode</b> 😭 thick book, extreme page curl</figcaption>
          </figure>
        </div>
      </section>

      <!-- PIPELINE -->
      <section class="flow">
        <div class="flow__intro">
          <h2 class="reveal">A powerful pipeline architecture</h2>
          <p class="reveal">Whether you're scanning books, spiral-bound reports, or loose sheets of paper, there's a specially curated pipeline for you.</p>
        </div>
        <div class="flow__steps">
          {steps.map((s) => (
            <article class="step reveal">
              <div class="step__lead">
                <svg class="step__ic" viewBox="0 0 24 24" width="64" height="64"
                     fill={s.fill ? 'currentColor' : 'none'}
                     stroke={s.fill ? 'none' : 'currentColor'}
                     stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"
                     aria-hidden="true" set:html={s.svg} />
              </div>
              <div>
                <h3>{s.t}</h3>
                <p>{s.d}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- CONTINUITY CAMERA -->
      <section class="continuity">
        <div class="continuity__copy reveal">
          <h2>Scan anywhere with the <span>continuity camera</span></h2>
          <p>Put your phone on your desk, your book on a chair, <i>et voilà</i> !</p>
          <p>With a typical capacity of <span>1&nbsp;page / sec</span> and a <span>sub-2&nbsp;seconds latency per scan</span>, you may not turn the pages fast enough to overwhelm Aglaïa.</p>
        </div>
        <figure class="continuity__demo reveal">
          <img src="/landing/usage.webp" width="760" height="874" loading="lazy" alt="Overhead diagram: a person at a laptop, an iPhone on a stand acting as the camera, pointed at an open book propped on a chair." />
        </figure>
      </section>

      <!-- SMART REPLAY -->
      <section class="replay">
        <div class="replay__copy reveal">
          <h2 class="replay__quip">How much resolution do you want? <span>— Yes!</span></h2>
          <p class="replay__sub">Smart replay — no iterative distortion.</p>
          <p>Deskew, keystone correction and dewarp each <em>resample</em> the
            image. Chain them naïvely and every pass softens and warps the
            pixels a little more — glyph edges crumble.</p>
          <p>Aglaïa <b>keeps track of the operations</b> and at the end composes
            the <b>perfect blend of geometric and morphological transforms</b> to
            give you the <b>sharpest result</b>.</p>
        </div>
        <div class="replay__demo reveal">
          <figure class="rp rp--bad">
            <img src="/landing/replay-distorted.webp" width="500" height="502" loading="lazy" alt="Text glyphs degraded and jagged from repeated per-step resampling." />
            <figcaption>Sequential processing</figcaption>
          </figure>
          <figure class="rp rp--good">
            <img src="/landing/replay-restored.webp" width="500" height="500" loading="lazy" alt="The same glyphs, crisp and clean, from a single replayed warp." />
            <figcaption>Smart replay</figcaption>
          </figure>
        </div>
      </section>

      <!-- PIPELINE SLIDESHOW -->
      <section class="gallery">
        <div class="gallery__head reveal">
          <h2>Watch a page take shape.</h2>
          <p>Every stage is persisted, inspectable and replayable.</p>
        </div>
        <div class="gallery__strip reveal">
          <figure class="shot"><img src="/landing/stage-1-detect.webp" height="760" loading="lazy" alt="Layout detection boxes the two pages of the spread and splits them." /><figcaption><b>1 · Detect</b> — split the spread into pages</figcaption></figure>
          <figure class="shot"><img src="/landing/stage-2-binarize.webp" height="760" loading="lazy" alt="The page binarized: crisp black text on white." /><figcaption><b>2 · Binarize</b> — crisp black on white</figcaption></figure>
          <figure class="shot"><img src="/landing/stage-3-trapezoid.webp" height="760" loading="lazy" alt="Trapezoidal keystone correction with the fitted column quad overlaid." /><figcaption><b>3 · Keystone</b> — remove perspective</figcaption></figure>
          <figure class="shot"><img src="/landing/stage-4-dewarp.webp" height="760" loading="lazy" alt="Page dewarp flattens the curved sheet and straightens the baselines." /><figcaption><b>4 · Dewarp</b> — flatten page curvature</figcaption></figure>
          <figure class="shot"><img src="/landing/stage-5-final.webp" height="760" loading="lazy" alt="The final clean rectified page, ready for OCR and export." /><figcaption><b>5 · Done</b> — straight, clean, ready for OCR</figcaption></figure>
        </div>
        <p class="gallery__hint reveal">scroll →</p>
      </section>

      <!-- POWER FEATURES -->
      <section class="features">
        <h2 class="reveal"><span>Simple</span>, but not simplistic</h2>
        <p class="features__sub reveal">Unleash the computer-vision and data-science nerd within you.</p>
        <div class="grid">
          {powers.map((f) => (
            <article class="feature reveal">
              <svg class="feature__ic" viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={f.svg} />
              <h3>{f.t}</h3>
              <p>{f.d}</p>
            </article>
          ))}
        </div>

        <h3 class="code__title reveal" id="install">Install from the command line</h3>
        <p class="code__lead reveal">GUI builds: <b>macOS</b> .dmg · <b>Windows</b> installer · <b>Linux</b> AppImage (above). For a CLI-only or scripted setup, use uv or pip on any platform.</p>
        <div class="code reveal">
          <div class="code__tabs">
            <button class="code__tab is-active" data-tab="brew" type="button">Homebrew (macOS)</button>
            <button class="code__tab" data-tab="uv" type="button">uv (source)</button>
            <button class="code__tab" data-tab="pip" type="button">pip</button>
            <button class="code__copy" type="button" aria-label="Copy">Copy</button>
          </div>
          <pre class="code__panel is-active" data-panel="brew"><code># macOS, Apple Silicon
brew tap yb85/aglaia https://github.com/yb85/aglaia
brew trust yb85/aglaia              # Homebrew 6.x: trust the third-party tap

brew install --cask aglaia          # the GUI app (notarized DMG) — recommended
# or, run from a terminal instead of a .app double-click:
brew install aglaia-cli             # same full app, launched via `aglaia …`
brew install aglaia-cli --without-gui   # lighter: CLI-only, no Qt/GUI

aglaia ~/scans/my-book</code></pre>
          <pre class="code__panel" data-panel="uv"><code># build from source with the extras you want
git clone https://github.com/yb85/aglaia.git &amp;&amp; cd aglaia

uv sync --extra gui --extra macos   # macOS GUI: Vision, Speech, MLX dewarp
uv sync --extra gui                 # Windows / Linux GUI (Qt only)
uv sync                             # headless: CLI pipeline, no Qt
# add any of:
#   --extra surya --extra paddle    # OCR engines — uv installs BOTH
#   --extra voice    # offline voice control (Vosk, cross-platform)
#   --extra cloud    # Mistral cloud OCR
#   --extra cuda     # NVIDIA GPU dewarp (Linux)

uv run aglaia ~/scans/my-book</code></pre>
          <pre class="code__panel" data-panel="pip"><code># from PyPI — installs the `aglaia` command
pip install aglaia                  # lean base: headless pipeline, no Qt
pip install "aglaia[gui]"           # Windows / Linux GUI (Qt)
pip install "aglaia[gui,macos]"     # macOS GUI: Vision, Speech, MLX dewarp

# OCR engines: pip can't install both (conflicting huggingface-hub pins),
# so pick one. This limit is pip-only — uv and the .app/installer ship both.
#   pip install "aglaia[surya]"     # Surya OCR (cross-platform)
#   pip install "aglaia[paddle]"    # PaddleOCR-VL
# Apple Vision OCR needs no extra — it ships with [macos].

aglaia ~/scans/my-book              # launch</code></pre>
        </div>
      </section>

      <!-- CTA -->
      <section class="final">
        <div class="final__inner reveal">
          <h2>Digitize your shelf.</h2>
          <p>Free, source-available<a class="asterisk" href="https://polyformproject.org/licenses/shield/1.0.0" target="_blank" rel="noopener">*</a>, and yours to extend.</p>
          <div class="cta">
            <div class="dl">
              <a class="btn btn--lg dl__main" href={DOWNLOADS.mac.url} data-download data-download-os>
                <span class="dl__label">Download for {DOWNLOADS.mac.name}</span>
                <span class="dl__sub">{DOWNLOADS.mac.sub}</span>
              </a>
              <button class="btn btn--lg dl__toggle" type="button"
                      aria-haspopup="true" aria-expanded="false" aria-label="Choose another platform">▾</button>
              <div class="dl__menu" role="menu" hidden>
                <a role="menuitem" data-os="mac"     href={DOWNLOADS.mac.url}><b>macOS</b><span>{DOWNLOADS.mac.sub}</span></a>
                <a role="menuitem" data-os="windows" href={DOWNLOADS.windows.url}><b>Windows</b><span>{DOWNLOADS.windows.sub}</span></a>
                <a role="menuitem" data-os="linux"   href={DOWNLOADS.linux.url}><b>Linux</b><span>{DOWNLOADS.linux.sub}</span></a>
              </div>
            </div>
            <a class="btn btn--ghost btn--lg" href={GITHUB}>Star on GitHub</a>
          </div>
          <p class="cta__note">CUDA GPU acceleration available via <a href="#install">CLI install</a> on Linux / WSL2.</p>
          <p class="license">* <a href="https://polyformproject.org/licenses/shield/1.0.0" target="_blank" rel="noopener">PolyForm Shield License 1.0.0</a></p>
        </div>
      </section>
    </main>

    <footer class="foot">
      <span>Aglaïa · bibli.cc</span>
      <nav>
        <a href="/docs">Docs</a>
        <a href={GITHUB}>Source</a>
        <a href={KOFI}>Tip</a>
      </nav>
    </footer>

    <script>
      // Reveal-on-scroll FIRST and independent of anything that can throw,
      // so the page content always appears even if smooth-scroll init fails.
      const revealEls = [...document.querySelectorAll('.reveal')];
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }
      }, { threshold: 0.18 });
      revealEls.forEach((el) => io.observe(el));
      // Failsafe: if the observer never fires (some browsers/extensions),
      // reveal everything shortly after load.
      addEventListener('load', () => setTimeout(
        () => revealEls.forEach((el) => el.classList.add('in')), 1000));

      // ── platform-aware downloads ──────────────────────────────────────
      // Detect the visitor's OS and point every download button at the right
      // fixed-name artifact. URLs live on the split-menu links, so they're
      // never duplicated here.
      const detectOS = (): 'mac' | 'windows' | 'linux' => {
        const nav = navigator as any;
        const p = ((nav.userAgentData && nav.userAgentData.platform)
          || navigator.platform || navigator.userAgent || '').toLowerCase();
        if (p.includes('win')) return 'windows';
        if (p.includes('mac') || p.includes('iphone') || p.includes('ipad')) return 'mac';
        if (p.includes('linux') && !p.includes('android')) return 'linux';
        return 'mac';   // default to the most mature build
      };
      const OS_NAME = { mac: 'macOS', windows: 'Windows', linux: 'Linux' };
      const os = detectOS();
      const menuLink = document.querySelector<HTMLAnchorElement>(`.dl__menu [data-os="${os}"]`);
      if (menuLink) {
        const url = menuLink.getAttribute('href') || '';
        const subText = menuLink.querySelector('span')?.textContent || '';
        document.querySelectorAll('[data-download]').forEach((a) => a.setAttribute('href', url));
        document.querySelectorAll<HTMLElement>('[data-download-os]').forEach((a) => {
          const label = a.querySelector<HTMLElement>('.dl__label') || a;
          label.textContent = `Download for ${OS_NAME[os]}`;
        });
        document.querySelectorAll<HTMLElement>('.dl__main .dl__sub').forEach((s) => {
          s.textContent = subText;
        });
      }

      // Split-button platform menus — one per .dl, only one open at a time.
      const closeAllDlMenus = () => {
        document.querySelectorAll('.dl__menu').forEach((m) => m.setAttribute('hidden', ''));
        document.querySelectorAll('.dl__toggle').forEach((t) => t.setAttribute('aria-expanded', 'false'));
      };
      document.querySelectorAll('.dl').forEach((dl) => {
        const toggle = dl.querySelector('.dl__toggle');
        const menu = dl.querySelector('.dl__menu');
        toggle?.addEventListener('click', (e) => {
          e.stopPropagation();
          const willOpen = menu?.hasAttribute('hidden');
          closeAllDlMenus();
          if (willOpen) { menu?.removeAttribute('hidden'); toggle.setAttribute('aria-expanded', 'true'); }
        });
      });
      document.addEventListener('click', (e) => {
        if (!(e.target as Element).closest('.dl')) closeAllDlMenus();
      });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAllDlMenus(); });

      // "CLI installation" → smooth-scroll to the install block (works with or
      // without the Lenis layer that loads below).
      document.querySelectorAll('a[href="#install"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const t = document.getElementById('install');
          if (!t) return;
          e.preventDefault();
          const lenis = (window as any).__lenis;
          if (lenis) lenis.scrollTo(t, { offset: -90 });
          else t.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Tiny shell syntax highlighter for the install code tabs — runs FIRST,
      // synchronously, before the `await import('lenis')` below, so it can
      // never be skipped by a slow/failed dynamic import. Wraps comments /
      // leading command / flags / quoted strings in spans; span text
      // concatenates back to the original, so Copy (textContent) is intact.
      try {
        const hlEsc = (s: string) =>
          s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const hlLine = (line: string): string => {
          let code = line, comment = '';
          const m = line.match(/(?:^|\s)#/);
          if (m) {
            const i = line.indexOf('#', m.index);
            code = line.slice(0, i);
            comment = line.slice(i);
          }
          let out = '', first = true;
          const re = /(\s+)|("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')|(\S+)/g;
          let t: RegExpExecArray | null;
          while ((t = re.exec(code))) {
            if (t[1]) { out += t[1]; continue; }
            if (t[2]) { out += `<span class="tok-str">${hlEsc(t[2])}</span>`; continue; }
            const w = t[3];
            if (first && /^[a-z]/i.test(w)) {
              out += `<span class="tok-cmd">${hlEsc(w)}</span>`; first = false; continue;
            }
            first = false;
            if (/^--?\w/.test(w)) { out += `<span class="tok-flag">${hlEsc(w)}</span>`; continue; }
            out += hlEsc(w);
          }
          if (comment) out += `<span class="tok-comment">${hlEsc(comment)}</span>`;
          return out;
        };
        document.querySelectorAll<HTMLElement>('.code__panel code').forEach((c) => {
          c.innerHTML = (c.textContent || '').split('\n').map(hlLine).join('\n');
        });
      } catch (err) {
        console.warn('Aglaïa: code highlight failed', err);
      }

      // Before/after swipes — each drives its own clip divider, and hides a
      // corner label once its image is mostly slid away.
      document.querySelectorAll<HTMLElement>('.ba').forEach((ba) => {
        const r = ba.querySelector<HTMLInputElement>('.ba__range');
        const sync = () => {
          const v = +(r?.value ?? 50);
          ba.style.setProperty('--pos', v + '%');
          ba.classList.toggle('ba--no-before', v < 16);
          ba.classList.toggle('ba--no-after', v > 84);
        };
        r?.addEventListener('input', sync);
        sync();
      });

      // Smooth scroll + parallax — progressive enhancement; a failure here
      // must never block the reveal above, so it's dynamically imported and
      // fully guarded.
      try {
        const { default: Lenis } = await import('lenis');
        const lenis = new Lenis({ lerp: 0.1, wheelMultiplier: 1 });
        (window as any).__lenis = lenis;   // used by the #install anchor scroll
        function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
        requestAnimationFrame(raf);
        const nav = document.getElementById('nav');
        const layers = [...document.querySelectorAll<HTMLElement>('[data-parallax]')];
        lenis.on('scroll', ({ scroll }: { scroll: number }) => {
          nav?.classList.toggle('nav--solid', scroll > 24);
          for (const el of layers) {
            const f = parseFloat(el.dataset.parallax || '0');
            el.style.transform = `translate3d(0, ${scroll * f}px, 0)`;
          }
        });
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) lenis.destroy();
      } catch (err) {
        console.warn('Aglaïa: smooth-scroll init failed; continuing without it', err);
      }

      // Install code tabs + copy.
      document.querySelectorAll<HTMLElement>('.code__tab').forEach((t) => {
        t.addEventListener('click', () => {
          const k = t.dataset.tab;
          document.querySelectorAll('.code__tab').forEach((x) => x.classList.toggle('is-active', x === t));
          document.querySelectorAll<HTMLElement>('.code__panel').forEach((p) =>
            p.classList.toggle('is-active', p.dataset.panel === k));
        });
      });

      const copyBtn = document.querySelector<HTMLButtonElement>('.code__copy');
      copyBtn?.addEventListener('click', async () => {
        const panel = document.querySelector('.code__panel.is-active code');
        if (!panel) return;
        try {
          await navigator.clipboard.writeText(panel.textContent || '');
          copyBtn.textContent = 'Copied';
          setTimeout(() => { copyBtn.textContent = 'Copy'; }, 1400);
        } catch { /* clipboard blocked — no-op */ }
      });
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
